// Локална функция за добавяне (замества API заявките на Base44)
export const addToCartLocal = (currentCart, newProduct) => {
  const existingItem = currentCart.find(item => item.product_id === newProduct.product_id);
  
  if (existingItem) {
    return currentCart.map(item =>
      item.product_id === newProduct.product_id
        ? { ...item, quantity: item.quantity + 1 }
        : item
    );
  }
  
  return [...currentCart, { ...newProduct, quantity: 1 }];
};
