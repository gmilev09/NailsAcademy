// Изчистен модел за Елемент в количка (CartItem)
export const CartItemSchema = {
  product_id: "",
  product_name: "",
  product_price: 0,
  product_image: "",
  quantity: 1,
  user_email: "" // Имейл на потребителя (незадължително за локална количка)
};

// Функция за изчисляване на общата сума на количката
export const calculateTotal = (cartItems) => {
  return cartItems.reduce((total, item) => {
    return total + (item.product_price * item.quantity);
  }, 0);
};

